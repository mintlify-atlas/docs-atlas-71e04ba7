  "keyFeatures": [
    "Custom live TV channel creation and scheduling",
    "IPTV and HDHomeRun (HDHR) streaming support",
    "Electronic Program Guide (EPG/XMLTV) generation",
    "Hardware-accelerated transcoding (NVENC, QSV, VAAPI, AMF, VideoToolbox)",
    "Media server integration (Plex, Jellyfin, Emby)",
    "Multiple scheduling modes (Classic, Block, Sequential, Scripted)",
    "Graphics engine for watermarks and overlays",
    "Music video and subtitle support",
    "Smart collections and filtering",
    "Docker deployment support"
  ],
  "publicApiSurface": [
    "GET /iptv/channels.m3u - Channel playlist",
    "GET /iptv/xmltv.xml - EPG guide",
    "GET /iptv/channel/{channelNumber}.ts - Stream video",
    "GET /api/channels - List channels",
    "POST /api/channels - Create channel",
    "GET /api/schedules - List schedules",
    "GET /api/libraries - List media libraries",
    "GET /api/media - Query media items",
    "GET /api/collections - List collections",
    "GET /discover.json - HDHomeRun discovery",
    "GET /device.xml - HDHomeRun device info",
    "GET /lineup.json - HDHomeRun lineup"
  ]
